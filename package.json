{
  "name": "codex-mcp",
  "version": "2.0.0",
  "description": "Claude Code MCP plugin — multi-agent code execution using your existing Claude session. No separate API key required.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codex-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "npm run build && node_modules/.bin/tsx scripts/setup.ts",
    "enable": "node_modules/.bin/tsx scripts/enable.ts",
    "disable": "claude mcp remove codex-mcp -s user",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "claude", "claude-code", "codex", "ai", "code-generation"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rolling-codes/codex-mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
